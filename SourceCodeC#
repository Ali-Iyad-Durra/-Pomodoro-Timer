using System;
using System.Windows;
using System.Windows.Media;
using System.Windows.Threading;
using System.Windows.Input;

namespace ModernPomodoro
{
    public partial class MainWindow : Window
    {
        DispatcherTimer timer = new DispatcherTimer();
        int timeLeft = 25 * 60;
        bool isWork = true;
        bool isRunning = false;
        bool isDark = false;

        public MainWindow()
        {
            InitializeComponent();
            timer.Interval = TimeSpan.FromSeconds(1);
            timer.Tick += Timer_Tick;
            UpdateUI();
        }

        private void Timer_Tick(object sender, EventArgs e)
        {
            if (timeLeft > 0)
            {
                timeLeft--;
                UpdateUI();
            }
            else
            {
                timer.Stop();
                System.Media.SystemSounds.Beep.Play();
                isWork = !isWork;
                timeLeft = isWork ? 25 * 60 : 5 * 60;
                TxtStatus.Text = isWork ? "FOCUS" : "BREAK";
                isRunning = false;
                BtnStart.Content = "Start";
                MessageBox.Show(isWork ? "Back to Work!" : "Break Time!");
                ApplyTheme(); // تحديث الألوان بعد انتهاء الجلسة
            }
        }

        private void UpdateUI()
        {
            TimeSpan t = TimeSpan.FromSeconds(timeLeft);
            TxtTimer.Text = string.Format("{0:D2}:{1:D2}", t.Minutes, t.Seconds);
        }

        private void BtnStart_Click(object sender, RoutedEventArgs e)
        {
            if (!isRunning) { timer.Start(); isRunning = true; BtnStart.Content = "Pause"; BtnStart.Background = Brushes.Orange; }
            else { timer.Stop(); isRunning = false; BtnStart.Content = "Resume"; BtnStart.Background = new SolidColorBrush(Color.FromRgb(99, 102, 241)); }
        }

        private void BtnReset_Click(object sender, RoutedEventArgs e)
        {
            timer.Stop(); isRunning = false; isWork = true;
            timeLeft = 25 * 60; UpdateUI(); TxtStatus.Text = "FOCUS";
            BtnStart.Content = "Start";
            BtnStart.Background = new SolidColorBrush(Color.FromRgb(99, 102, 241));
            ApplyTheme();
        }

        private void ApplyTheme()
        {
            if (isDark) {
                MainBorder.Background = new SolidColorBrush(Color.FromRgb(30, 30, 30));
                TxtTimer.Foreground = Brushes.White;
                TimerRing.Stroke = new SolidColorBrush(Color.FromRgb(60, 60, 60));
                BtnTheme.Content = "☀️";
                BtnReset.Background = new SolidColorBrush(Color.FromRgb(60, 60, 60));
                BtnReset.Foreground = Brushes.White;
                TxtDeveloper.Foreground = Brushes.Gray;
            } else {
                MainBorder.Background = new SolidColorBrush(Color.FromRgb(248, 250, 252));
                TxtTimer.Foreground = new SolidColorBrush(Color.FromRgb(30, 41, 59));
                TimerRing.Stroke = new SolidColorBrush(Color.FromRgb(226, 232, 240));
                BtnTheme.Content = "🌙";
                BtnReset.Background = new SolidColorBrush(Color.FromRgb(226, 232, 240));
                BtnReset.Foreground = new SolidColorBrush(Color.FromRgb(30, 41, 59));
                TxtDeveloper.Foreground = new SolidColorBrush(Color.FromRgb(148, 163, 184));
            }
            if (!isWork) TxtStatus.Foreground = Brushes.LightGreen;
            else TxtStatus.Foreground = isDark ? Brushes.Gray : new SolidColorBrush(Color.FromRgb(148, 163, 184));
        }

        private void BtnTheme_Click(object sender, RoutedEventArgs e) { isDark = !isDark; ApplyTheme(); }

        private void BtnMax_Click(object sender, RoutedEventArgs e)
        {
            this.WindowState = (this.WindowState == WindowState.Normal) ? WindowState.Maximized : WindowState.Normal;
            MainBorder.CornerRadius = (this.WindowState == WindowState.Maximized) ? new CornerRadius(0) : new CornerRadius(25);
        }

        private void BtnClose_Click(object sender, RoutedEventArgs e) => this.Close();

        private void Window_MouseDown(object sender, MouseButtonEventArgs e)
        {
            if (e.LeftButton == MouseButtonState.Pressed) DragMove();
        }
    }
}
